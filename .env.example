# ChiefOps Website — Environment Variables
# Copy this file to .env.local for local development

# Site
NEXT_PUBLIC_SITE_URL=https://chiefops.co.za

# WhatsApp (for FAB, hero CTA, contact page, footer, schema)
# Full international format, no spaces: e.g. 27821234567
NEXT_PUBLIC_WHATSAPP_NUMBER=27000000000

# Contact email (for audit form, footer, schema)
NEXT_PUBLIC_CONTACT_EMAIL=info@chiefops.co.za

# Web3Forms (for audit form submission — get key at https://web3forms.com)
# Leave blank for demo mode (forms won't send)
WEB3FORMS_KEY=your-web3forms-access-key

# Resend (optional — for auto-reply to leads)
RESEND_API_KEY=your-resend-api-key

# Cloudflare Turnstile (optional — for spam protection)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# Google Analytics (optional)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
